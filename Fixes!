        ['Diamond Head Trail Lot', 2.75, 21.261563, -157.805661],
    ];

    $stmt = $conn->prepare("INSERT INTO parking_spots (location, price_per_hour, latitude, longitude) VALUES (?, ?, ?, ?)");

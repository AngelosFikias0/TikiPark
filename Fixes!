$checkSpots = $conn->query("SELECT COUNT(*) as count FROM parking_spots");
$row = $checkSpots->fetch_assoc();

if ((int)$row['count'] === 0) {
    $spots = [
        ['Ala Moana Mall', 3.50, 21.291982, -157.843144],
        ['Waikiki Beachfront', 4.00, 21.275760, -157.827507],
